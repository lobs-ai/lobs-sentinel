{
  "name": "lobs-sentinel",
  "version": "0.1.0",
  "description": "Persistent single-purpose AI agents for GitHub — PR review, issue triage, labeling",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.1"
  }
}
